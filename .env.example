# Supabase database access for CLI / manual SQL workflows
# In IPv4-only or proxy-heavy networks, keep the session pooler URL and also add a
# transaction pooler URL. The migration check script will prefer the transaction
# pooler first because it is often more reliable for short-lived CLI commands.
SUPABASE_DB_URL=postgresql://postgres.xaoqhaakrzolcyivqutn:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres
SUPABASE_TRANSACTION_POOLER_URL=postgresql://postgres.xaoqhaakrzolcyivqutn:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres
